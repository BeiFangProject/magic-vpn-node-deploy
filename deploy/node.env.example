# 节点基础信息，后续应由主服务器管理后台生成
NODE_ID=replace-with-node-id
NODE_NAME=jp-tokyo-01
NODE_TOKEN=replace-with-node-token
CONTROL_API_URL=https://api.example.com

# 后台显示和调度使用
NODE_REGION=asia
NODE_COUNTRY_CODE=JP
NODE_CITY=Tokyo

# WireGuard 配置
WG_INTERFACE=wg0
WG_PORT=51820
WG_ADDRESS=10.66.0.1/24
WG_CONFIG_PATH=/etc/wireguard/wg0.conf

# 节点对客户端暴露的连接地址，留空时脚本自动使用公网 IP
ENDPOINT_HOST=

# 出口网卡，留空时脚本会自动识别默认出口网卡
PUBLIC_INTERFACE=

# 客户端 DNS，可按业务需要调整
CLIENT_DNS=1.1.1.1
